# --- WhatsApp Cloud API ---
# Token temporal (o del System User) que te da Meta en el dashboard
WHATSAPP_TOKEN=
# ID del número de teléfono de prueba (Meta > WhatsApp > API Setup)
WHATSAPP_PHONE_NUMBER_ID=
# String secreto inventado por vos, debe coincidir con el que cargues en Meta
WEBHOOK_VERIFY_TOKEN=mi-token-secreto-123

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Servidor ---
PORT=3000
